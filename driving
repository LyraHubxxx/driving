local function isMoving()
    local c = LocalPlayer.Character
    if not c or not c:FindFirstChild("HumanoidRootPart") then return false, Vector3.new() end
    local dir = Vector3.new(Camera.CFrame.LookVector.X, 0, Camera.CFrame.LookVector.Z).Unit
    local m = Vector3.new()
    if UserInputService:IsKeyDown(Enum.KeyCode.W) then m = m + dir end
    if UserInputService:IsKeyDown(Enum.KeyCode.S) then m = m - dir end
    if UserInputService:IsKeyDown(Enum.KeyCode.D) then m = m + Vector3.new(-dir.Z, 0, dir.X) end
    if UserInputService:IsKeyDown(Enum.KeyCode.A) then m = m + Vector3.new(dir.Z, 0, -dir.X) end
    if m.Magnitude > 0 then return true, m.Unit else return false, Vector3.new() end
end

